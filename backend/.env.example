# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Paste your full connection string from Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/growthpilot?retryWrites=true&w=majority

# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Vercel frontend URL)
# Example: https://growthpilot.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
